# Rhizome Configuration
# Copy this file to .env and fill in your values.

# Qdrant vector store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=modernity-v1
# QDRANT_API_KEY=your_qdrant_api_key  # Optional, for Qdrant Cloud

# Embedder type: openai or huggingface
EMBEDDER_TYPE=openai

# OpenAI API key (required if EMBEDDER_TYPE=openai)
OPENAI_API_KEY=your_openai_api_key

# HuggingFace API token (required if EMBEDDER_TYPE=huggingface)
# HF_API_TOKEN=your_hf_token

# HuggingFace model (default: sentence-transformers/all-MiniLM-L6-v2)
# HF_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Wikipedia categories to ingest (comma-separated, also overridable via --categories flag)
WIKIPEDIA_CATEGORIES=Modernism,Postmodernism,Critical theory

# Traversal parameters
DEFAULT_DEPTH=8
EPSILON=0.1
